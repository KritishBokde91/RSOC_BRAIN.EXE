# ============================================================
# AetherVerify — Environment Configuration
# Copy this file to `.env` and fill in values.
# ============================================================

# ── Groq / LLM ──────────────────────────────────────────────
GROQ_API_KEY=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
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=qwen/qwen3-32b

Alternatively, use generic AETHERVERIFY_ prefixed keys:
AETHERVERIFY_LLM_API_KEY=
AETHERVERIFY_LLM_BASE_URL=
AETHERVERIFY_LLM_MODEL=

── Ollama (local embeddings & reranking) ────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
AETHERVERIFY_EMBEDDING_MODEL=snowflake-arctic-embed2:latest
AETHERVERIFY_RERANKER_MODEL=

── Neo4j (optional, for persistent graph storage) ──────────
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

── Docker sandbox ──────────────────────────────────────────
AETHERVERIFY_CONTAINER_IMAGE=node:22-bookworm
